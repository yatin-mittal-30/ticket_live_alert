# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Slack Bot Token and Channel
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Optional: @mention these users on ticket alerts (comma-separated). Default in code if unset.
# SLACK_NOTIFY_USER_IDS=U059XXXX,U059YYYY

# Monitoring settings
CHECK_INTERVAL_SECONDS=90
ALERT_COOLDOWN_MINUTES=10

# Set to true to enable headless mode (no browser window)
HEADLESS=true

# Slack-only “still running” ping (local main.py loop). Telegram is not used for this.
SLACK_HEARTBEAT_ENABLED=true
SLACK_HEARTBEAT_MINUTES=30
